{
  "name": "@dayflower/tw-lint",
  "version": "0.3.0",
  "description": "An unofficial Tailwind CSS linter CLI powered by the Tailwind CSS language server.",
  "type": "module",
  "bin": {
    "tw-lint": "dist/cli.mjs"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:action": "tsdown -c tsdown.action.config.ts && node scripts/vendor-language-server.mjs",
    "prepublishOnly": "npm run check && npm run typecheck && npm run build",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "fix": "biome check --write .",
    "test:fixtures": "npm --prefix test/fixtures/v3 install --no-audit --no-fund && npm --prefix test/fixtures/v4 install --no-audit --no-fund",
    "pretest": "npm run test:fixtures",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "lint",
    "linter",
    "cli",
    "lsp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dayflower/tw-lint.git"
  },
  "homepage": "https://github.com/dayflower/tw-lint#readme",
  "bugs": {
    "url": "https://github.com/dayflower/tw-lint/issues"
  },
  "dependencies": {
    "@tailwindcss/language-server": "^0.14.29",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.17",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.1",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@biomejs/biome": "2.5.1",
    "@types/node": "^22.0.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
